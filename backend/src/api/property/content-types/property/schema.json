{
  "kind": "collectionType",
  "collectionName": "properties",
  "info": {
    "singularName": "property",
    "pluralName": "properties",
    "displayName": "Property Type",
    "description": "Unit types within buildings (e.g., Type-A 2BR, Type-B 3BR)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "name_ar": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "description_ar": {
      "type": "text"
    },
    "price": {
      "type": "decimal"
    },
    "area": {
      "type": "decimal"
    },
    "bedrooms": {
      "type": "integer",
      "default": 0
    },
    "bathrooms": {
      "type": "integer",
      "default": 0
    },
    "living_rooms": {
      "type": "integer",
      "default": 0
    },
    "balconies": {
      "type": "integer",
      "default": 0
    },
    "working_rooms": {
      "type": "integer",
      "default": 0
    },
    "floors": {
      "type": "integer",
      "default": 1
    },
    "display_order": {
      "type": "integer",
      "default": 0
    },
    "total_units": {
      "type": "integer",
      "default": 0
    },
    "available_units": {
      "type": "integer",
      "default": 0
    },
    "property_status": {
      "type": "enumeration",
      "enum": ["available", "reserved", "sold"],
      "default": "available"
    },
    "property_type": {
      "type": "enumeration",
      "enum": ["apartment", "villa", "penthouse", "studio", "townhouse", "commercial"],
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"]
    },
    "floorplan": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "extra_features": {
      "type": "json"
    },
    "extra_features_ar": {
      "type": "json"
    },
    "building": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::building.building",
      "inversedBy": "properties"
    }
  }
}
